        echo "═══════════════════════════════════════════"
        echo "  ARCHITECTURE REVIEW OUTPUT"
        echo "═══════════════════════════════════════════"
        echo ""
        cat "$output_file"
        echo ""
    fi

    if ! check_result; then
        exit 1
    fi
}

cmd_metrics() {
    require_tool jq

    local json_output=false
    [[ "${1:-}" == "--json" ]] && json_output=true

    load_config

    local sprints_file="$ARCHIVE_DIR/sprints.jsonl"
    local backlog_file="$BACKLOG_DIR/backlog.json"
    local bugs_file="$BACKLOG_DIR/bugs.json"

    local ready_backlog
    ready_backlog=$(count_ready_items "$backlog_file")
    local ready_bugs
    ready_bugs=$(count_ready_items "$bugs_file")

    local backlog_total
    backlog_total=$(count_items "$backlog_file")
    local bugs_total
    bugs_total=$(count_items "$bugs_file")

    if [[ "$json_output" == "true" ]]; then
        local completed
        completed=$([[ -f "$sprints_file" ]] && jq -s 'length' "$sprints_file" 2>/dev/null || echo 0)

        # Build trends object if archive exists
        local trends="{}"
        if [[ -f "$sprints_file" && -s "$sprints_file" ]]; then
            trends=$(jq -s '
                def safe_div(a; b): if b == 0 then 0 else (a / b * 100 | round) / 100 end;
                . as $all |
                {
                    avgAttempts: safe_div([$all[] | .attempts // 1] | add; $all | length),
                    itemsPerDay: safe_div($all | length; [$all[] | .date] | unique | length),
                    byPriority: ([$all[] | {priority: (.priority // "unknown")}] | group_by(.priority) | map({key: .[0].priority, value: length}) | from_entries),
                    byCategory: ([$all[] | {category: (.category // "uncategorized")}] | group_by(.category) | map({key: .[0].category, value: length}) | from_entries)
                } + (
                    if ($all | length) > 10 then
                        ($all | [.[length-10:][]] ) as $recent |
                        {
                            recentAvgAttempts: safe_div([$recent[] | .attempts // 1] | add; $recent | length),
                            recentAvgDuration: safe_div([$recent[] | .duration // 0] | add; $recent | length)
                        }
                    else {} end
                )
            ' "$sprints_file" 2>/dev/null || echo "{}")
        fi

        cat <<EOF
{
  "timestamp": "$(date -Iseconds)",
  "sprints": {"completed": $completed},
  "backlog": {"total": $backlog_total, "ready": $ready_backlog},
  "bugs": {"total": $bugs_total, "ready": $ready_bugs},
  "trends": $trends
}
EOF
    else
        log_header "aishore Metrics"
        echo ""
        echo "Completed Sprints: $([[ -f "$sprints_file" ]] && jq -s 'length' "$sprints_file" 2>/dev/null || echo 0)"
        echo ""
        echo "Backlog:"
        echo "  Total items: $backlog_total"
        echo "  Ready for sprint: $ready_backlog"
        echo ""
        echo "Bugs/Tech Debt:"
        echo "  Total items: $bugs_total"
        echo "  Ready for sprint: $ready_bugs"

        # Trends section
        if [[ -f "$sprints_file" && -s "$sprints_file" ]]; then
            echo ""
            log_subheader "Trends"
            local trend_count
            trend_count=$(jq -s 'length' "$sprints_file" 2>/dev/null || echo 0)

            local avg_attempts items_per_day
            avg_attempts=$(jq -s 'if length == 0 then 0 else ([.[] | .attempts // 1] | add / length * 100 | round) / 100 end' "$sprints_file" 2>/dev/null || echo 0)
            items_per_day=$(jq -s 'if length == 0 then 0 else (length / ([.[] | .date] | unique | length) * 100 | round) / 100 end' "$sprints_file" 2>/dev/null || echo 0)
            echo "  Avg attempts/item: $avg_attempts"
            echo "  Items/day: $items_per_day"

            # By priority
            local by_priority
            by_priority=$(jq -sr '[.[] | .priority // "unknown"] | group_by(.) | map("\(.[0]): \(length)") | join(", ")' "$sprints_file" 2>/dev/null || true)
            [[ -n "$by_priority" ]] && echo "  By priority: $by_priority"

            # By category
            local by_category
            by_category=$(jq -sr '[.[] | .category // "uncategorized"] | group_by(.) | map("\(.[0]): \(length)") | join(", ")' "$sprints_file" 2>/dev/null || true)
            [[ -n "$by_category" ]] && echo "  By category: $by_category"

            # Recent trend (last 10 vs overall)
            if [[ "$trend_count" -gt 10 ]]; then
                local recent_avg_attempts overall_avg_attempts
                recent_avg_attempts=$(jq -s '([.[length-10:][]] | [.[] | .attempts // 1] | add / length * 100 | round) / 100' "$sprints_file" 2>/dev/null || echo 0)
                overall_avg_attempts="$avg_attempts"
                echo "  Recent trend (last 10): avg attempts $recent_avg_attempts (overall: $overall_avg_attempts)"

                local recent_avg_duration overall_avg_duration
                recent_avg_duration=$(jq -s '([.[length-10:][]] | [.[] | .duration // 0] | add / length | round)' "$sprints_file" 2>/dev/null || echo 0)
                overall_avg_duration=$(jq -s '([.[] | .duration // 0] | add / length | round)' "$sprints_file" 2>/dev/null || echo 0)
                echo "  Recent trend (last 10): avg duration ${recent_avg_duration}s (overall: ${overall_avg_duration}s)"
            fi
        fi
    fi
}

cmd_status() {
    require_tool jq

    local backlog_file="$BACKLOG_DIR/backlog.json"
    local bugs_file="$BACKLOG_DIR/bugs.json"
    local sprints_file="$ARCHIVE_DIR/sprints.jsonl"

    log_header "Backlog Status"
    echo ""

    # --- Item counts by status ---
    if [[ -f "$backlog_file" ]]; then
        echo "Features: $(count_by_status "$backlog_file" "todo") todo, $(count_by_status "$backlog_file" "in-progress") in-progress, $(count_by_status "$backlog_file" "done") done"
    else
        log_warning "Backlog is empty"
    fi

    if [[ -f "$bugs_file" ]]; then
        echo "Bugs: $(count_by_status "$bugs_file" "todo") todo, $(count_by_status "$bugs_file" "in-progress") in-progress, $(count_by_status "$bugs_file" "done") done"
    fi

    # --- Ready for sprint ---
    echo ""
    log_subheader "Ready for sprint"
    local has_ready=false

    for f in "$backlog_file" "$bugs_file"; do
        [[ -f "$f" ]] || continue
        local ready
        ready=$(list_ready_items "$f")
        if [[ -n "$ready" ]]; then
            echo "$ready"
            has_ready=true
        fi
    done

    if [[ "$has_ready" == "false" ]]; then
        log_warning "No items ready for sprint — run 'groom' or 'backlog edit <ID> --ready'"
    fi

    # --- Recent sprints ---
    echo ""
    log_subheader "Recent sprints"
    if [[ -f "$sprints_file" ]] && [[ -s "$sprints_file" ]]; then
        jq -r '"\(.date) \(.itemId) \(.status)"' "$sprints_file" 2>/dev/null | tail -5 | while IFS= read -r line; do
            echo "  $line"
        done
    else
        log_info "No sprints run yet"
    fi

    # --- Warnings ---
    if [[ ! -f "$backlog_file" ]] && [[ ! -f "$bugs_file" ]]; then
        echo ""
        log_warning "Backlog is empty — run 'backlog add' to create items"
    fi

    local total=0 done_total=0
    for f in "$backlog_file" "$bugs_file"; do
        [[ -f "$f" ]] || continue
        total=$((total + $(count_items "$f")))
        done_total=$((done_total + $(count_by_status "$f" "done")))
    done
    if [[ "$total" -gt 0 && "$total" -eq "$done_total" ]]; then
        echo ""
        log_info "All items completed"
    fi
}

