save_backlog_snapshot() {
    local snapshot_dir="$STATUS_DIR/backlog-snapshot"
    mkdir -p "$snapshot_dir"
    for f in "${BACKLOG_FILES[@]}"; do
        [[ -f "$BACKLOG_DIR/$f" ]] && cp "$BACKLOG_DIR/$f" "$snapshot_dir/$f" || true
    done
}

restore_backlog_snapshot() {
    local snapshot_dir="$STATUS_DIR/backlog-snapshot"
    for f in "${BACKLOG_FILES[@]}"; do
        [[ -f "$snapshot_dir/$f" ]] && cp "$snapshot_dir/$f" "$BACKLOG_DIR/$f" || true
    done
}

mark_item_failed() {
    local item_id="$1"
    local reason="$2"
    local source="$3"
    [[ -z "$source" ]] && return 0
    local now
    now=$(date -Iseconds)
    update_item "$source" "$item_id" \
        '| . + {lastFailReason: $reason, lastFailAt: $ts, failCount: ((.failCount // 0) + 1)}' \
        --arg reason "$reason" --arg ts "$now" 2>/dev/null || true
}

handle_sprint_failure() {
    log_warning "Resetting working tree after sprint failure"
    # If on a feature branch, switch back to base and delete the branch
    # (base branch still has backlog state from earlier successful sprints)
    if [[ -n "$AISHORE_FEATURE_BRANCH" && -n "$AISHORE_BASE_BRANCH" ]]; then
        local fb="$AISHORE_FEATURE_BRANCH"
        AISHORE_FEATURE_BRANCH=""
        git checkout "$AISHORE_BASE_BRANCH" 2>/dev/null || true
        git branch -D "$fb" 2>/dev/null || true
    else
        # Fallback for non-branching context
        local snapshot_dir="$STATUS_DIR/backlog-snapshot"
        local has_snapshot=false
        [[ -d "$snapshot_dir" ]] && has_snapshot=true

        git reset HEAD -- . 2>/dev/null || true
        git checkout -- . 2>/dev/null || true
        git clean -fd -e '.aishore' 2>/dev/null || true

        if [[ "$has_snapshot" == true ]]; then
            restore_backlog_snapshot
        fi
    fi
    reset_sprint
}

