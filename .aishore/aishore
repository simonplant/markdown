cmd_backlog() {
    require_tool jq
    local subcmd="${1:-list}"
    shift || true
    case "$subcmd" in
        list|ls)    cmd_backlog_list "$@" ;;
        add|new)    cmd_backlog_add "$@" ;;
        show)       cmd_backlog_show "$@" ;;
        edit)       cmd_backlog_edit "$@" ;;
        rm|remove)  cmd_backlog_rm "$@" ;;
        check)      cmd_backlog_check "$@" ;;
        populate)   cmd_backlog_populate "$@" ;;
        *)
            log_error "Unknown backlog command: $subcmd"
            echo "Usage: backlog {list|add|show|edit|check|rm|populate}" >&2
            return 1
            ;;
    esac
}

cmd_backlog_check() {
    local id="${1:-}"
    [[ -z "$id" ]] && { log_error "Usage: backlog check <ID>"; return 1; }

    # Verify item exists
    find_item "$id" >/dev/null || return 1

    if check_readiness_gates "$id"; then
        log_success "$id passes all readiness gates"
    else
        log_warning "$id has readiness warnings:"
        echo -e "$CHECK_GATES_WARNINGS"
    fi
}

cmd_backlog_populate() {
    if [[ ! -f "$BACKLOG_DIR/backlog.json" ]]; then
        log_error "aishore not initialized — run '.aishore/aishore init' first"
        return 1
    fi

    acquire_lock
    load_config
    cd "$PROJECT_ROOT"

    log_header "Product Owner: Populate Backlog"

    # Find product requirements doc
    local prd_file=""
    for candidate in \
        "$PROJECT_ROOT/PRODUCT.md" "$PROJECT_ROOT/product.md" \
        "$PROJECT_ROOT/PRD.md" "$PROJECT_ROOT/prd.md" \
        "$PROJECT_ROOT/docs/PRODUCT.md" "$PROJECT_ROOT/docs/product.md" \
        "$PROJECT_ROOT/docs/PRD.md" "$PROJECT_ROOT/docs/prd.md" \
        "$PROJECT_ROOT/docs/WEBSITE_BRIEF.md" \
        "$PROJECT_ROOT/README.md"; do
        if [[ -f "$candidate" ]]; then
            prd_file="$candidate"
            break
        fi
    done

    if [[ -z "$prd_file" ]]; then
        log_error "No product requirements doc found (PRODUCT.md, PRD.md, README.md, etc.)"
        echo "  Create a PRODUCT.md or docs/PRODUCT.md describing what you're building."
        return 1
    fi

    # Guard against empty scaffold templates
    local content_lines
    content_lines=$(grep -cvE '^\s*$|^\s*#|^\s*<!--|^\s*-->|^\s*- \[ \]' "$prd_file" 2>/dev/null || echo 0)
    if [[ "$content_lines" -lt 3 ]]; then
        log_error "Product doc appears to be an empty template: $prd_file"
        echo "  Fill in your product vision, target users, and core features before populating."
        echo "  The backlog quality depends entirely on the quality of this document."
        return 1
    fi

    log_info "Using requirements from: $prd_file"

    local context_args="@$prd_file @$BACKLOG_DIR/backlog.json @$BACKLOG_DIR/bugs.json"
    # Include definitions doc for quality examples if available
    [[ -f "$BACKLOG_DIR/DEFINITIONS.md" ]] && context_args="$context_args @$BACKLOG_DIR/DEFINITIONS.md"

    # Snapshot backlog state for progress tracking
    local snap_before
    snap_before=$(snapshot_backlogs)

    log_info "Running product-owner agent to populate backlog..."
    echo ""

    GROOM_MONITOR=true run_agent "product-owner" "populate" "$MODEL_FAST" "$context_args"

    # --- Post-populate diff ---
    print_groom_diff "$snap_before"

    if ! check_result; then
        exit 1
    fi
}

cmd_backlog_list() {
    local filter_status="" filter_type="" filter_ready=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --status)  filter_status="$2"; shift 2 ;;
            --type)    filter_type="$2"; shift 2 ;;
            --ready)   filter_ready=true; shift ;;
            *) log_error "Unknown option: $1"; return 1 ;;
        esac
    done

    # Determine which files to scan
    local files=()
    case "$filter_type" in
        feat|feature) files=("backlog.json") ;;
        bug)          files=("bugs.json") ;;
        "")           files=("${BACKLOG_FILES[@]}") ;;
        *) log_error "Invalid type: $filter_type (must be: feat, bug)"; return 1 ;;
    esac

    # Build jq filter
    local jq_filter='.items[]'
    if [[ -n "$filter_status" ]]; then
        validate_status "$filter_status" || return 1
        jq_filter="$jq_filter | select((.status // \"todo\") == \"$filter_status\")"
    fi
    if [[ "$filter_ready" == "true" ]]; then
        jq_filter="$jq_filter | select(.readyForSprint == true)"
    fi

    # Header
    printf "%-10s %-8s %-13s %-6s %s\n" "ID" "PRI" "STATUS" "READY" "TITLE"
    printf "%-10s %-8s %-13s %-6s %s\n" "──────────" "────────" "─────────────" "──────" "─────────────────────────────"

    local count=0
    for f in "${files[@]}"; do
        [[ -f "$BACKLOG_DIR/$f" ]] || continue
        local items
        items=$(jq -r "[$jq_filter] | sort_by(if .priority == \"must\" then 0 elif .priority == \"should\" then 1 elif .priority == \"could\" then 2 else 3 end) | .[] | [.id, .priority // \"-\", .status // \"todo\", (if .readyForSprint then \"yes\" else \"no\" end), .title] | @tsv" "$BACKLOG_DIR/$f" 2>/dev/null) || continue
        if [[ -n "$items" ]]; then
            while IFS=$'\t' read -r id pri status ready title; do
                printf "%-10s %-8s %-13s %-6s %s\n" "$id" "$pri" "$status" "$ready" "$title"
                ((count++)) || true
            done <<< "$items"
        fi
    done

    echo ""
    echo "$count item(s)"
}

cmd_backlog_add() {
    local item_type="feat" title="" intent="" desc="" priority="should" category="" ready=false
    local -a ac_entries=()
    local pending_ac=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --type)      item_type="$2"; shift 2 ;;
            --title)     title="$2"; shift 2 ;;
            --intent)    intent="$2"; shift 2 ;;
            --desc)      desc="$2"; shift 2 ;;
            --priority)  priority="$2"; shift 2 ;;
            --category)  category="$2"; shift 2 ;;
            --ready)     ready=true; shift ;;
            --ac)
                # Flush any pending AC entry as plain string
                if [[ -n "$pending_ac" ]]; then
                    ac_entries+=("$(printf '%s' "$pending_ac" | jq -Rs .)")
                fi
                pending_ac="$2"
                shift 2 ;;
            --ac-verify)
                if [[ -z "$pending_ac" ]]; then
                    log_error "--ac-verify must follow --ac"
                    return 1
                fi
                ac_entries+=("{\"text\":$(printf '%s' "$pending_ac" | jq -Rs .),\"verify\":$(printf '%s' "$2" | jq -Rs .)}")
                pending_ac=""
                shift 2 ;;
            *) log_error "Unknown option: $1"; return 1 ;;
        esac
    done

    # Flush last pending AC
    if [[ -n "$pending_ac" ]]; then
        ac_entries+=("$(printf '%s' "$pending_ac" | jq -Rs .)")
    fi

    # Interactive mode if no title
    if [[ -z "$title" ]]; then
        if [[ ! -t 0 ]]; then
            log_error "No --title provided and stdin is not interactive"
            return 1
        fi
        echo "Add new backlog item"
        echo ""

        read -r -p "Type (feat/bug) [$item_type]: " input
        [[ -n "$input" ]] && item_type="$input"

        read -r -p "Title: " title
        [[ -z "$title" ]] && { log_error "Title is required"; return 1; }

        read -r -p "Intent (commander's intent — what must be true when done): " intent

        read -r -p "Description: " desc

        read -r -p "Priority (must/should/could/future) [$priority]: " input
        [[ -n "$input" ]] && priority="$input"

        read -r -p "Category: " category
    fi

    # Validate
    case "$item_type" in
        feat|feature) item_type="feat" ;;
        bug) ;;
        *) log_error "Invalid type: $item_type (must be: feat, bug)"; return 1 ;;
    esac
    validate_priority "$priority" || return 1

    # Determine prefix and target file
    local prefix target_file
    if [[ "$item_type" == "feat" ]]; then
        prefix="FEAT"
        target_file="backlog.json"
    else
        prefix="BUG"
        target_file="bugs.json"
    fi

    # Generate ID
    local new_id
    new_id=$(next_id "$prefix")

    # Build AC array
    local ac_json="[]"
    if [[ ${#ac_entries[@]} -gt 0 ]]; then
        ac_json="["
        local first=true
        for entry in "${ac_entries[@]}"; do
            [[ "$first" == "true" ]] && first=false || ac_json="$ac_json,"
            ac_json="$ac_json$entry"
        done
        ac_json="$ac_json]"
    fi

    # Create item and append
    if ! add_item "$target_file" \
        --arg id "$new_id" \
        --arg title "$title" \
        --arg intent "$intent" \
        --arg desc "$desc" \
        --arg priority "$priority" \
        --arg category "$category" \
        --argjson ready "$ready" \
        --argjson ac_arr "$ac_json" \
        '.items += [{
            id: $id,
            title: $title,
            intent: (if $intent == "" then null else $intent end),
            description: $desc,
            priority: $priority,
            category: (if $category == "" then null else $category end),
            steps: [],
            acceptanceCriteria: $ac_arr,
            status: "todo",
            passes: false,
            readyForSprint: $ready
        }]'; then
        log_error "Failed to add item"
        return 1
    fi

    log_success "Created $new_id: $title"
}

cmd_backlog_show() {
    local id="${1:-}"
    [[ -z "$id" ]] && { log_error "Usage: backlog show <ID>"; return 1; }

    local item
    item=$(find_item "$id") || return 1

    echo ""
    echo "$item" | jq -r '
        "ID:          \(.id)",
        "Title:       \(.title)",
        "Status:      \(.status // "todo")",
        "Priority:    \(.priority // "-")",
        "Category:    \(.category // "-")",
        "Ready:       \(if .readyForSprint then "yes" else "no" end)",
        "Passes:      \(if .passes then "yes" else "no" end)",
        "",
        if .intent then "Intent:      \(.intent)\n" else empty end,
        "Description: \(.description // "-")",
        "",
        if (.steps // [] | length) > 0 then "Steps:" else empty end,
        (.steps // [] | to_entries[] | "  \(.key + 1). \(.value)"),
        if (.steps // [] | length) > 0 then "" else empty end,
        if (.acceptanceCriteria // [] | length) > 0 then "Acceptance Criteria:" else empty end,
        (.acceptanceCriteria // [] | .[] | "  - \(.)"),
        if (.dependsOn // [] | length) > 0 then "\nDependencies: \(.dependsOn | join(", "))" else empty end,
        if .groomedAt then "\nGroomed:      \(.groomedAt)" else empty end,
        if .groomingNotes then "Notes:        \(.groomingNotes)" else empty end,
        if .completedAt then "Completed:    \(.completedAt)" else empty end
    '
}

cmd_backlog_edit() {
    local id="${1:-}"
    [[ -z "$id" ]] && { log_error "Usage: backlog edit <ID> [--title ...] [--intent ...] [--priority ...] [--status ...] [--desc ...] [--category ...] [--ready] [--no-ready]"; return 1; }
    shift

    # Verify item exists
    find_item "$id" >/dev/null || return 1

    local file
    file=$(resolve_backlog_file "$id") || return 1

    # Parse update flags
    local updates=() update_desc=""
    local jq_updates=""
    local setting_ready=false
    local -a ac_entries=()
    local pending_ac=""
    local -a scope_vals=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --title)
                validate_arg "$1" "${2:-}" || return 1
                jq_updates="$jq_updates | .title = \$title"
                updates+=("--arg" "title" "$2")
                update_desc="$update_desc title"
                shift 2 ;;
            --intent)
                validate_arg "$1" "${2:-}" || return 1
                jq_updates="$jq_updates | .intent = \$intent"
                updates+=("--arg" "intent" "$2")
                update_desc="$update_desc intent"
                shift 2 ;;
            --desc)
                validate_arg "$1" "${2:-}" || return 1
                jq_updates="$jq_updates | .description = \$desc"
                updates+=("--arg" "desc" "$2")
                update_desc="$update_desc description"
                shift 2 ;;
            --priority)
                validate_arg "$1" "${2:-}" || return 1
                validate_priority "$2" || return 1
                jq_updates="$jq_updates | .priority = \$priority"
                updates+=("--arg" "priority" "$2")
                update_desc="$update_desc priority"
                shift 2 ;;
            --status)
                validate_arg "$1" "${2:-}" || return 1
                validate_status "$2" || return 1
                jq_updates="$jq_updates | .status = \$status"
                updates+=("--arg" "status" "$2")
                update_desc="$update_desc status"
                shift 2 ;;
            --category)
                validate_arg "$1" "${2:-}" || return 1
                jq_updates="$jq_updates | .category = \$category"
                updates+=("--arg" "category" "$2")
                update_desc="$update_desc category"
                shift 2 ;;
            --ready)
                jq_updates="$jq_updates | .readyForSprint = true"
                update_desc="$update_desc ready"
                setting_ready=true
                shift ;;
            --no-ready)
                jq_updates="$jq_updates | .readyForSprint = false"
                update_desc="$update_desc ready"
                shift ;;
            --scope)
                validate_arg "$1" "${2:-}" || return 1
                scope_vals+=("$2")
                update_desc="$update_desc scope"
                shift 2 ;;
            --clear-scope)
                jq_updates="$jq_updates | .scope = []"
                update_desc="$update_desc scope"
                shift ;;
            --ac)
                validate_arg "$1" "${2:-}" || return 1
                # Flush any pending AC entry
                if [[ -n "$pending_ac" ]]; then
                    ac_entries+=("$pending_ac")
                fi
                pending_ac="$2"
                update_desc="$update_desc ac"
                shift 2 ;;
            --ac-verify)
                validate_arg "$1" "${2:-}" || return 1
                if [[ -z "$pending_ac" ]]; then
                    log_error "--ac-verify must follow --ac"
                    return 1
                fi
                # Convert pending AC to object with verify
                ac_entries+=("{\"text\":$(printf '%s' "$pending_ac" | jq -Rs .),\"verify\":$(printf '%s' "$2" | jq -Rs .)}")
                pending_ac=""
                shift 2 ;;
            --groomed-notes)
                validate_arg "$1" "${2:-}" || return 1
                jq_updates="$jq_updates | .groomingNotes = \$gnotes"
                updates+=("--arg" "gnotes" "$2")
                update_desc="$update_desc groomingNotes"
                shift 2 ;;
            --groomed-at)
                local gdate
                if [[ -n "${2:-}" && "${2:-}" != --* ]]; then
                    gdate="$2"
                    shift 2
                else
                    gdate=$(date +%Y-%m-%d)
                    shift
                fi
                jq_updates="$jq_updates | .groomedAt = \$gdate"
                updates+=("--arg" "gdate" "$gdate")
                update_desc="$update_desc groomedAt"
                ;;
            *) log_error "Unknown option: $1"; return 1 ;;
        esac
    done

    # Flush last pending AC entry (plain string)
    if [[ -n "$pending_ac" ]]; then
        ac_entries+=("$(printf '%s' "$pending_ac" | jq -Rs .)")
    fi

    # Build scope jq update if any --scope flags were used
    if [[ ${#scope_vals[@]} -gt 0 ]]; then
        local scope_json
        scope_json=$(printf '%s\n' "${scope_vals[@]}" | jq -R . | jq -s .)
        jq_updates="$jq_updates | .scope = ((.scope // []) + \$newscope)"
        updates+=("--argjson" "newscope" "$scope_json")
    fi

    # Build AC jq update if any --ac flags were used
    if [[ ${#ac_entries[@]} -gt 0 ]]; then
        local ac_json="["
        local first=true
        for entry in "${ac_entries[@]}"; do
            [[ "$first" == "true" ]] && first=false || ac_json="$ac_json,"
            # If entry starts with { it's already JSON, otherwise it's a jq-encoded string
            if [[ "$entry" == "{"* ]]; then
                ac_json="$ac_json$entry"
            else
                ac_json="$ac_json$entry"
            fi
        done
        ac_json="$ac_json]"
        jq_updates="$jq_updates | .acceptanceCriteria = ((.acceptanceCriteria // []) + \$newac)"
        updates+=("--argjson" "newac" "$ac_json")
    fi

    if [[ -z "$jq_updates" ]]; then
        log_error "No updates specified. Use --title, --priority, --status, --desc, --category, --ready, --no-ready, --scope, --ac, --ac-verify"
        return 1
    fi

    if ! update_item "$file" "$id" "$jq_updates" "${updates[@]}"; then
        log_error "Failed to update item"
        return 1
    fi

    log_success "Updated $id:$update_desc"

    # Run readiness gates when setting --ready (warn but don't block)
    if [[ "$setting_ready" == "true" ]]; then
        if ! check_readiness_gates "$id"; then
            log_warning "Readiness warnings for $id:"
            echo -e "$CHECK_GATES_WARNINGS"
        fi
    fi
}

validate_arg() {
    local flag="$1" val="$2"
    if [[ -z "$val" || "$val" == --* ]]; then
        log_error "$flag requires a value"
        return 1
    fi
}

cmd_backlog_rm() {
    local id="${1:-}" force=false
    [[ -z "$id" ]] && { log_error "Usage: backlog rm <ID> [--force]"; return 1; }
    shift || true

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force|-f) force=true; shift ;;
            *) log_error "Unknown option: $1"; return 1 ;;
        esac
    done

    local item
    item=$(find_item "$id") || return 1
    local title
    title=$(echo "$item" | jq -r '.title')

    local file
    file=$(resolve_backlog_file "$id") || return 1

    if [[ "$force" == "false" ]]; then
        echo "Remove $id: $title?"
        read -r -p "Confirm (y/N): " confirm
        [[ "$confirm" != "y" && "$confirm" != "Y" ]] && { echo "Cancelled"; return 0; }
    fi

    if ! remove_item "$file" "$id"; then
        log_error "Failed to remove item"
        return 1
    fi

    log_success "Removed $id: $title"
}

cmd_clean() {
    require_tool jq

    local dry_run=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run) dry_run=true; shift ;;
            *) log_error "Unknown option: $1"; return 1 ;;
        esac
    done

    local feat_count=0 bug_count=0

    local backlog_file="$BACKLOG_DIR/backlog.json"
    local bugs_file="$BACKLOG_DIR/bugs.json"

    [[ -f "$backlog_file" ]] && feat_count=$(count_by_status "$backlog_file" "done")
    [[ -f "$bugs_file" ]] && bug_count=$(count_by_status "$bugs_file" "done")

    local total=$((feat_count + bug_count))

    if [[ "$total" -eq 0 ]]; then
        echo "Nothing to clean"
    elif [[ "$dry_run" == "true" ]]; then
        echo "Would remove: $feat_count features, $bug_count bugs"
    else
        [[ "$feat_count" -gt 0 ]] && remove_items_by_status "$backlog_file" "done"
        [[ "$bug_count" -gt 0 ]] && remove_items_by_status "$bugs_file" "done"
        echo "Cleaned $feat_count features, $bug_count bugs ($total total removed)"
    fi
}

